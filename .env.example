# CodeRAG Environment Configuration
# Copy this file to .env and fill in your actual values

# ===== REQUIRED =====

# Google Gemini API Key (required for AI features)
# Get yours at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI API Key (Alternative LLM)
OPENAI_API_KEY=your_openai_api_key

# Anthropic API Key (Alternative LLM)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Default LLM Provider (gemini, openai, anthropic)
DEFAULT_LLM_PROVIDER=gemini

# GitHub OAuth App Credentials
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:5173/settings?tab=github

# Stripe Billing Credentials
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Frontend URL for CORS and Redirects
FRONTEND_URL=http://localhost:5173

# ===== OPTIONAL =====

# Authentication Security
# Generate a strong secret key for JWT tokens
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace_with_32_plus_char_random_value

# Allowlisted git hosts for ingestion URL validation
GIT_HOST_ALLOWLIST=github.com,www.github.com

# CORS Configuration
# Comma-separated list of allowed origins, or "*" for all
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Local LLM Configuration (Alternative to Google Gemini)
# Set to "true" to use Ollama instead of Google Gemini
USE_LOCAL_LLM=false
LOCAL_LLM_MODEL=llama3
LOCAL_EMBEDDING_MODEL=nomic-embed-text

# Rate Limiting (requests per minute)
CHAT_RATE_LIMIT=10
INGEST_RATE_LIMIT=5

# Database Configuration
# Production/Docker uses Postgres by default.
# For local development without Docker, you must install Postgres or switch to SQLite (not recommended for features).
# SQL_ALCHEMY_DATABASE_URL=sqlite+aiosqlite:///./coderag.db
SQL_ALCHEMY_DATABASE_URL=postgresql+asyncpg://coderag:coderag@localhost:5432/coderag

# Redis Configuration (Required for Celery Worker)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Logging Level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Observability
# Sentry DSN for frontend error tracking
VITE_SENTRY_DSN=
